{
	"name": "@victor-software-house/pi-multicodex",
	"version": "1.0.5",
	"description": "Codex account rotation extension for pi",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"extension",
		"codex",
		"openai",
		"oauth"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"image": "https://raw.githubusercontent.com/victor-founder/pi-multicodex/main/assets/multicodex.png"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/victor-founder/pi-multicodex.git"
	},
	"homepage": "https://github.com/victor-founder/pi-multicodex#readme",
	"bugs": {
		"url": "https://github.com/victor-founder/pi-multicodex/issues"
	},
	"author": "Victor",
	"files": [
		"abort-utils.ts",
		"account-manager.ts",
		"browser.ts",
		"commands.ts",
		"extension.ts",
		"hooks.ts",
		"index.ts",
		"provider.ts",
		"quota.ts",
		"selection.ts",
		"status.ts",
		"storage.ts",
		"stream-wrapper.ts",
		"usage-client.ts",
		"usage.ts",
		"README.md",
		"LICENSE",
		"assets/**"
	],
	"scripts": {
		"lint": "biome check .",
		"test": "vitest run -c vitest.config.ts",
		"tsgo": "tsgo -p tsconfig.json",
		"check": "pnpm lint && pnpm tsgo && pnpm test",
		"pack:dry": "npm pack --dry-run",
		"release:dry": "bun ./scripts/publish.ts --dry-run",
		"release:prepare": "bun ./scripts/publish.ts"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@mariozechner/pi-ai": "^0.58.1",
		"@mariozechner/pi-coding-agent": "^0.58.1",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260314.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": "24.14.0"
	}
}
